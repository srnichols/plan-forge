# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts — always LF
*.sh text eol=lf

# PowerShell — always CRLF on Windows, but store as LF in repo
*.ps1 text eol=lf

# Markdown — normalize
*.md text

# JSON — normalize
*.json text

# YAML — normalize
*.yml text
*.yaml text

# Templates — normalize
*.template text

# Ignore for diff (binary-like or generated)
*.png binary
*.jpg binary
*.gif binary
*.ico binary

pforge text eol=lf

# Generated artifact — suppress from GitHub diffs
docs/assets/tailwind.built.css linguist-generated=true

# ---------------------------------------------------------------------------
# Plan Forge maintainer hygiene — exclude internal dev artifacts from
# `git archive` tarballs and "Download ZIP" so consumers cloning master never
# get Plan Forge's own dev planning artifacts. These paths should never land
# on master (they live on `planning/main`); these are belt-and-suspenders
# rules in case anything leaks back.
# ---------------------------------------------------------------------------
docs/plans/archive/                  export-ignore
docs/plans/Phase-*-PLAN.md           export-ignore
docs/plans/PHASE-*-RUNBOOK.md        export-ignore
docs/plans/DEPLOYMENT-ROADMAP.md     export-ignore
docs/plans/cleanup-findings/         export-ignore
docs/plans/testbed-findings/         export-ignore
