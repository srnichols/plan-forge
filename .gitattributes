# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts — always LF
*.sh text eol=lf

# PowerShell — always CRLF on Windows, but store as LF in repo
*.ps1 text eol=lf

# Markdown — normalize
*.md text

# JSON — normalize
*.json text

# YAML — normalize
*.yml text
*.yaml text

# Templates — normalize
*.template text

# Ignore for diff (binary-like or generated)
*.png binary
*.jpg binary
*.gif binary
*.ico binary

pforge text eol=lf

# Generated artifact — suppress from GitHub diffs
docs/assets/tailwind.built.css linguist-generated=true

# ─── Release tarball hygiene (`git archive` / GitHub Release tarball) ──────────
# Dev-internal artifacts that must NEVER ship in a consumer release tarball,
# even when the release tag happens to live on `planning/main` (the dev superset
# branch). See AGENTS.md "Branch Model" for rationale.
#
# Verify after a release:
#   git archive --format=tar v<X.Y.Z> | tar -tf - | grep -E 'Phase-.*-PLAN\.md|^[^/]+/AGENTS\.md$'
# Should print nothing.
docs/plans/Phase-*-PLAN.md       export-ignore
docs/plans/archive/              export-ignore
docs/plans/cleanup-findings/     export-ignore
docs/plans/DEPLOYMENT-ROADMAP.md export-ignore
docs/plans/PROJECT-PRINCIPLES.md export-ignore
AGENTS.md                        export-ignore
