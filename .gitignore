# OS
.DS_Store
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Node.js
node_modules/
.vite/

# Generated by setup wizard
.forge.json

# Runtime data (generated by server — any .forge/ directory at any depth)
# Includes .forge/fm-prefs.json (Forge-Master user preferences)
**/.forge/

# MCP dependencies (users run npm install themselves)
pforge-mcp/node_modules/

# Auto-generated by MCP server on startup (regenerate with: node pforge-mcp/server.mjs)
# tools.json IS tracked (it's the canonical tool registry, hand-maintained
# alongside server.mjs CallToolRequestSchema). cli-schema.json is generated.
pforge-mcp/cli-schema.json

# Agent adapter outputs (generated per-project, not part of template)
CLAUDE.md
GEMINI.md
.claude/
.gemini/
.cursor/
.windsurf/
.agents/

# LiveGuard operational data (contains incident details, secret scan results, deploy history)
.forge/incidents/
.forge/secret-scan-cache.json
.forge/deploy-journal.jsonl
.forge/deploy-journal-meta.json
.forge/liveguard-events.jsonl
.forge/notifications/

# Phase-26 competitive worktrees (transient per-variant workspaces + archives)
.forge/worktrees/
.forge/worktrees-archive/

# LiveGuard auto-generated fix plans (runtime artifacts, not source-controlled)
docs/plans/auto/*
!docs/plans/auto/README.md

# Phase-38.3 knowledge graph snapshot (runtime artifact, not source-controlled)
.forge/graph/

# Testbed findings (local audit trail, not repo history)
docs/plans/testbed-findings/*.json

# Rummag poller artifacts (not part of Plan Forge)
.issues.json
.rummag-baseline.txt
.rummag-poller.ps1

.pr-body-*.md

.forge/hammer-forge-master/reports/

# Temporary scratch files
.tmp-*

# Validation harness runtime artifacts (probes.json + per-session results live
# under .forge/validation/ which is already gitignored via **/.forge/, but
# call out here to make the intent explicit if anyone moves them).
.forge/validation/

# Archived test files (when scripts/tests are retired, archive in-repo by
# rename; once verified safe, remove. Don't track .archived in master.)
**/*.test.mjs.archived
**/*.test.js.archived

# Stale duplicate of pforge-mcp/dashboard/ (removed in repo cleanup; ignored
# to prevent accidental re-introduction).
mcp/

# Stray empty workspace directory (never tracked).
plan-forge-master/

