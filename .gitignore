# OS
.DS_Store
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Node.js
node_modules/
.vite/

# Generated by setup wizard
.forge.json

# Runtime data (generated by server — any .forge/ directory at any depth)
**/.forge/

# MCP dependencies (users run npm install themselves)
pforge-mcp/node_modules/

# Auto-generated by MCP server on startup (regenerate with: node pforge-mcp/server.mjs)
pforge-mcp/cli-schema.json
pforge-mcp/tools.json

# Agent adapter outputs (generated per-project, not part of template)
CLAUDE.md
GEMINI.md
.claude/
.gemini/
.cursor/
.windsurf/
.agents/

# LiveGuard operational data (contains incident details, secret scan results, deploy history)
.forge/incidents/
.forge/secret-scan-cache.json
.forge/deploy-journal.jsonl
.forge/deploy-journal-meta.json
.forge/liveguard-events.jsonl

# LiveGuard auto-generated fix plans (runtime artifacts, not source-controlled)
docs/plans/auto/*
!docs/plans/auto/README.md

# Rummag poller artifacts (not part of Plan Forge)
.issues.json
.rummag-baseline.txt
.rummag-poller.ps1

.pr-body-*.md
