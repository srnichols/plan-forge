{
  "name": "plan-forge",
  "version": "3.8.1",
  "private": true,
  "workspaces": [
    "pforge-mcp",
    "pforge-master",
    "pforge-sdk"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "test:mcp": "npm test --workspace=pforge-mcp",
    "test:master": "npm test --workspace=pforge-master",
    "smoke:forge-master": "FORGE_SMOKE=1 node scripts/smoke-forge-master.mjs",
    "audit:full": "node scripts/audit/clean-code-review.mjs",
    "audit:dep-boundaries": "node scripts/audit/dep-boundaries.mjs",
    "audit:dep-direction": "node scripts/audit/dependency-direction.mjs",
    "build:css": "tailwindcss -i docs/assets/tailwind.css -o docs/assets/tailwind.built.css --minify",
    "postbuild:css": "node -e \"const{createHash}=require('crypto'),fs=require('fs');const h=createHash('sha256').update(fs.readFileSync('docs/assets/tailwind.built.css')).digest('hex');fs.writeFileSync('docs/assets/tailwind.built.css.sha256',h);console.log('CSS hash updated:',h.slice(0,12)+'…');\""
  },
  "devDependencies": {
    "eslint": "^9",
    "jscpd": "^4",
    "madge": "^7",
    "tailwindcss": "^3.4.0"
  }
}
