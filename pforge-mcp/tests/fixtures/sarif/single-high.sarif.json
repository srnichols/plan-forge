{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "version": "2.15.4",
          "rules": [
            {
              "id": "js/sql-injection",
              "name": "SqlInjection",
              "shortDescription": { "text": "Database query built from user-controlled sources" },
              "fullDescription": { "text": "Building a database query using string concatenation with user-provided data allows an attacker to modify the query logic." },
              "defaultConfiguration": { "level": "error" },
              "properties": {
                "tags": ["security", "correctness", "external/cwe/cwe-089"],
                "securitySeverity": "8.8"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "js/sql-injection",
          "ruleIndex": 0,
          "message": { "text": "This query depends on a user-provided value." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/db/queries.js", "uriBaseId": "%SRCROOT%" },
                "region": { "startLine": 42, "startColumn": 10, "endLine": 42, "endColumn": 55 }
              }
            }
          ],
          "level": "error"
        }
      ]
    }
  ]
}
