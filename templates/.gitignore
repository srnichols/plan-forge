# OS
.DS_Store
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Node.js
node_modules/

# Generated by setup wizard
.forge.json

# Runtime data (generated by server — any .forge/ directory at any depth)
**/.forge/

# MCP server runtime artifacts — Anvil Δ-only cache and Lattice code index
# (gitignored by default; rebuild with: pforge anvil rebuild / pforge lattice index)
.forge/anvil/
.forge/lattice/

# LiveGuard operational data
.forge/incidents/
.forge/secret-scan-cache.json
.forge/deploy-journal.jsonl
.forge/deploy-journal-meta.json
.forge/liveguard-events.jsonl
.forge/notifications/

# Phase competitive worktrees (transient per-variant workspaces)
.forge/worktrees/
.forge/worktrees-archive/

# LiveGuard auto-generated fix plans (runtime artifacts)
docs/plans/auto/*
!docs/plans/auto/README.md

# Knowledge graph snapshot (runtime artifact)
.forge/graph/

# Validation harness runtime artifacts
.forge/validation/

# Agent adapter outputs (generated per-project)
CLAUDE.md
GEMINI.md
.claude/
.gemini/
.cursor/
.windsurf/
.agents/

# Temporary scratch files
.tmp-*
